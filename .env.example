# Court Scoreboard Environment Variables
# Copy this file to .env and fill in your values

# Node Environment
NODE_ENV=production

# Application Port (Docker internal)
PORT=80

# Domain Configuration
VITE_APP_DOMAIN=scoreboard.example.com

# API Configuration (if used in future)
# VITE_API_URL=https://api.example.com

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false

# Storage Configuration
# localStorage is used by default for persistence
# BroadcastChannel is used for cross-tab sync

# SSL/TLS (managed by Nginx, not needed in app)
# HTTPS is enforced at Nginx level

# Notes:
# - All VITE_* variables are available in the browser (build-time)
# - Do NOT include sensitive secrets that should be private
# - This is a frontend-only application (no backend required)
